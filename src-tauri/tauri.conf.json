{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "MVPM",
	"version": "0.1.0",
	"identifier": "com.matmcw.mvpm",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "MVPM - Minecraft Voice Pack Maker",
				"width": 1024,
				"height": 700,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/icon.png",
			"icons/icon.ico"
		]
	}
}
